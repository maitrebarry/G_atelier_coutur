# ===== Mobile (Expo) environment =====
# Use same backend APIs as web app.
# Web default local API: http://localhost:8081/api

# local | prod
EXPO_PUBLIC_ENV=local

# --- LOCAL DEV (phone on same Wi-Fi as backend machine) ---
# Put your machine LAN IP where Spring Boot runs.
# Example: http://172.20.10.5:8081/api
EXPO_PUBLIC_API_BASE_URL_LOCAL=http://YOUR_LAN_IP:8081/api

# Optional explicit override (wins in local and prod)
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:8081/api

# Optional API port when building from host
EXPO_PUBLIC_API_PORT=8081

# Optional explicit host override (useful for Android emulator)
# EXPO_PUBLIC_DEV_HOST=10.0.2.2

# --- PROD ---
EXPO_PUBLIC_API_BASE_URL_PROD=https://g-atelier-backend.onrender.com/api
