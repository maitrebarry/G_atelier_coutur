# Configuration ATELIKO Laravel Mobile
# Ce fichier configure mobile_laravel pour consommer les API Laravel
# mobile_new reste configuré pour Spring Boot (port 8081)

# URL de l'API Laravel (port 8000 par défaut)
EXPO_PUBLIC_API_PORT=8000

# URL explicite pour LAN (remplacer par votre IP si nécessaire)
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.199:8000/api

# Environnement
EXPO_PUBLIC_ENV=local

# Pour production Laravel
# EXPO_PUBLIC_API_BASE_URL_PROD=https://votre-domaine-laravel.com/api
