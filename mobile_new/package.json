{
  "name": "g-atelier-mobile-new",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:local": "EXPO_PUBLIC_ENV=local expo start --lan --port 8088",
    "start:local:offline": "EXPO_PUBLIC_ENV=local EXPO_OFFLINE=1 expo start --offline --port 8088",
    "start:prod": "EXPO_PUBLIC_ENV=prod expo start --tunnel --port 8088",
    "start:android:local": "EXPO_PUBLIC_ENV=local EXPO_PUBLIC_DEV_HOST=10.0.2.2 expo start --android --port 8088",
    "start:lan": "expo start --lan --port 8088",
    "start:tunnel": "expo start --tunnel --port 8088",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.13.5",
    "expo": "^54.0.33",
    "expo-camera": "~17.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-flash-message": "^0.2.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "babel-preset-expo": "~54.0.10"
  }
}
