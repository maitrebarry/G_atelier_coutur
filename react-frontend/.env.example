# ===== Web (CRA) environment =====
# Convention aligned with mobile `mobile_new/src/utils/env.js`.

# local | prod
REACT_APP_ENV=local

# Optional explicit URL (wins over local/prod values)
# REACT_APP_API_BASE_URL=http://172.20.10.5:8081/api

# Local development URL
REACT_APP_API_BASE_URL_LOCAL=http://localhost:8081/api
REACT_APP_API_PORT=8081

# Production URL
REACT_APP_API_BASE_URL_PROD=https://g-atelier-backend.onrender.com/api
