{
  "expo": {
    "name": "g-atelier-mobile",
    "slug": "g-atelier-mobile",
    "version": "1.0.0",
    "entryPoint": "./mobile_new/App.js",
    "orientation": "portrait",
    "icon": "./mobile_new/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./mobile_new/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./mobile_new/assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./mobile_new/assets/favicon.png"
    }
  }
}
